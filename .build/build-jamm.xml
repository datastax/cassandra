<project basedir=".." name="apache-cassandra-jamm-build"
         xmlns:resolver="antlib:org.apache.maven.resolver.ant"
         xmlns:if="ant:if">
    <target name="_build-jamm" depends="resolver-init" unless="no-build-jamm">
      <!-- jamm is built from the modules/jamm submodule so Cassandra ships a build that behaves correctly
           on JDK 25, where the UseEmptySlotsInSupers VM option jamm probes was removed (the upstream 0.4.0
           mis-detects that, choosing the wrong sizing strategy and printing a warning to stdout that
           corrupts tool output). It is built and installed to the local Maven repository as
           org.apache.cassandra:cassandra-jamm:${version} (mirroring how Accord is built) so the parent
           pom resolves it from the local build rather than the upstream com.github.jbellis:jamm release.
           Compiled to match the JDK building Cassandra. -->
      <!-- Populate the submodule if the CI checkout did not recurse into it.
           Shallow clones without recurse-submodules leave modules/jamm/src empty. -->
      <exec executable="git" dir="${basedir}" failonerror="true">
        <arg value="submodule"/>
        <arg value="update"/>
        <arg value="--init"/>
        <arg value="${jamm.dir}"/>
      </exec>
      <property name="jamm.build.dir" location="${basedir}/${jamm.dir}/build"/>
      <property name="jamm.build.classes" location="${jamm.build.dir}/classes"/>
      <delete dir="${jamm.build.dir}" quiet="true"/>
      <mkdir dir="${jamm.build.classes}"/>
      <javac srcdir="${basedir}/${jamm.dir}/src" destdir="${jamm.build.classes}"
             includeantruntime="false" encoding="utf-8" debug="true"
             source="${ant.java.version}" target="${ant.java.version}">
        <!-- jamm references sun.misc.Unsafe; allow it like the main build does -->
        <compilerarg value="-XDignore.symbol.file"/>
        <compilerarg line="${jdk11plus-javac-exports}"/>
        <!-- jamm has no annotation processors; do not require -proc:full on JDK 23+ -->
        <compilerarg value="-proc:none"/>
      </javac>
      <jar destfile="${jamm.build.dir}/${jamm.final.name}.jar" basedir="${jamm.build.classes}">
        <manifest>
          <attribute name="Premain-Class" value="org.github.jamm.MemoryMeter"/>
        </manifest>
      </jar>
      <!-- Minimal pom so the artifact installs under the Cassandra coordinates. jamm has no runtime deps. -->
      <echo file="${jamm.build.dir}/${jamm.final.name}.pom">&lt;project xmlns="http://maven.apache.org/POM/4.0.0"&gt;
  &lt;modelVersion&gt;4.0.0&lt;/modelVersion&gt;
  &lt;groupId&gt;org.apache.cassandra&lt;/groupId&gt;
  &lt;artifactId&gt;cassandra-jamm&lt;/artifactId&gt;
  &lt;version&gt;${version}&lt;/version&gt;
  &lt;packaging&gt;jar&lt;/packaging&gt;
&lt;/project&gt;
</echo>
      <!-- install to the local Maven repository (aether install, no mvn needed; handles snapshot metadata) -->
      <resolver:install>
        <resolver:pom file="${jamm.build.dir}/${jamm.final.name}.pom"/>
        <resolver:artifact file="${jamm.build.dir}/${jamm.final.name}.jar" type="jar"/>
      </resolver:install>
      <!-- copy the freshly-built jar into the build lib directory so the compiler can find it -->
      <copy todir="${build.dir.lib}/jars" overwrite="true">
        <fileset dir="${jamm.build.dir}" includes="${jamm.final.name}.jar"/>
      </copy>
    </target>
</project>
